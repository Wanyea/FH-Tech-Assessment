{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["node", "vitest/globals"],
    "noEmit": true
  },
  "include": [
    "tests/**/*.ts",
    "tools/**/*.ts",
    "src/server/**/*.ts",
    "src/mp3/**/*.ts",
    "src/client/**/*.ts"
  ]
}
